# Copy to .env and fill in your values

# Discord bot token (required for --serve mode)
DISCORD_BOT_TOKEN=

# OpenAI API key (future)
# OPENAI_API_KEY=

# Brave Search API key (for web_search tool)
BRAVE_API_KEY=

# Trello (for trello tool)
TRELLO_API_KEY=
TRELLO_TOKEN=

# Google OAuth2 (for gmail + google_calendar tools)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Enable Gmail API + Google Calendar API
# Use OAuth consent flow to get a refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Copy to .env and fill in your values

# Discord bot token (required for --serve mode)
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=

# OpenAI API key (or any OpenAI-compatible API)
OPENAI_API_KEY=

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=

# Brave Search API key (for web_search tool)
BRAVE_API_KEY=

# Trello (for trello tool)
TRELLO_API_KEY=
TRELLO_TOKEN=

# Google services via gog CLI (for gmail, google_calendar, google_drive tools)
# Install gog: https://github.com/chzyer/gog
# Run: gog auth login
GOG_ACCOUNT=
GOG_KEYRING_PASSWORD=

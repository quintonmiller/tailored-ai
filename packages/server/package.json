{
  "name": "@agent/server",
  "version": "0.1.0",
  "description": "Agent HTTP API server (Hono routes, SSE, webhooks, static UI serving)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "hono": "^4.11.8",
    "yaml": "^2.6.0",
    "@agent/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}

{
  "name": "@tailored-ai/cli",
  "version": "0.1.0",
  "description": "Tailored AI — lightweight, modular AI agent framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tai": "dist/index.js"
  },
  "files": [
    "dist/",
    "ui-dist/"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "cp -r ../ui/dist ui-dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "dotenv": "^17.2.4",
    "yaml": "^2.6.0",
    "@agent/core": "workspace:*",
    "@agent/server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
